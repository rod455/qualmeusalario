<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Qual Meu Salário — Seu salário</title>
<style>
  * { box-sizing:border-box; margin:0; padding:0; -webkit-tap-highlight-color:transparent; }
  html,body { height:100%; background:#fff; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; }
  .phone { max-width:390px; min-height:100vh; margin:0 auto; background:#fff; display:flex; flex-direction:column; }

  .topbar { padding:16px 22px 12px; display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
  .back-btn { background:none; border:none; font-size:22px; color:#8e8e93; cursor:pointer; line-height:1; padding:2px 4px; }
  .logo-name { font-size:14px; font-weight:700; color:#1a1a1a; }
  .step-indicator { font-size:12px; font-weight:600; color:#aeaeb2; }

  .progress-bar { height:3px; background:#f2f2f7; flex-shrink:0; }
  .progress-fill { height:100%; background:#1D9E75; width:100%; }

  .content { flex:1; overflow-y:auto; padding:28px 24px 16px; display:flex; flex-direction:column; gap:0; -webkit-overflow-scrolling:touch; }

  .step-badge { display:inline-flex; align-items:center; gap:6px; background:#e8f8f2; color:#0F6E56; font-size:12px; font-weight:700; padding:5px 12px; border-radius:20px; margin-bottom:16px; text-transform:uppercase; letter-spacing:0.5px; }
  h1 { font-size:26px; font-weight:800; color:#1a1a1a; line-height:1.25; letter-spacing:-0.5px; margin-bottom:6px; }
  .subtitle { font-size:15px; color:#8e8e93; line-height:1.4; margin-bottom:28px; }

  .fg { margin-bottom:20px; }
  .fg-label { font-size:12px; font-weight:700; color:#8e8e93; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:8px; display:block; }
  .fg-label-row { display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; }
  .fg-sublabel { font-size:11px; color:#aeaeb2; font-weight:400; text-transform:none; letter-spacing:0; }

  /* BIG SALARY INPUT */
  .sal-big-wrap { position:relative; }
  .sal-prefix-big { position:absolute; left:16px; top:50%; transform:translateY(-50%); font-size:18px; font-weight:700; color:#aeaeb2; pointer-events:none; }
  input.sal-big {
    width:100%; padding:16px 16px 16px 52px;
    font-size:24px; font-weight:800; letter-spacing:-0.5px;
    border:1.5px solid #e5e5ea; border-radius:14px;
    background:#fff; color:#1a1a1a; font-family:inherit;
    transition:border-color 0.15s, box-shadow 0.15s;
  }
  input.sal-big:focus { outline:none; border-color:#1D9E75; box-shadow:0 0 0 3px rgba(29,158,117,0.1); }
  input.sal-big::placeholder { color:#d1d1d6; font-weight:500; }
  .sal-ano { font-size:13px; color:#aeaeb2; margin-top:6px; }

  /* DIVIDER */
  .divider { display:flex; align-items:center; gap:10px; margin:4px 0 16px; }
  .divider span { font-size:11px; font-weight:700; color:#aeaeb2; text-transform:uppercase; letter-spacing:0.5px; white-space:nowrap; }
  .divider::before,.divider::after { content:''; flex:1; height:1px; background:#f2f2f7; }

  /* EXTRA TOGGLES */
  .extra-toggles { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:16px; }
  .ext-tog {
    padding:8px 15px; font-size:14px; font-weight:600;
    border:1.5px solid #e5e5ea; border-radius:20px;
    cursor:pointer; background:#fff; color:#8e8e93;
    font-family:inherit; transition:all 0.15s;
  }
  .ext-tog.active { background:#e8f8f2; color:#0F6E56; border-color:#5DCAA5; }

  /* EXTRA FIELDS */
  .ext-field { display:none; margin-bottom:14px; }
  .ext-field.vis { display:block; }
  .sal-row { display:flex; align-items:center; gap:8px; }
  .sal-prefix { padding:12px 14px; border:1.5px solid #e5e5ea; border-radius:12px; font-size:15px; font-weight:700; color:#8e8e93; background:#f9f9f9; white-space:nowrap; flex-shrink:0; }
  input[type="number"] { flex:1; padding:12px 14px; font-size:16px; border:1.5px solid #e5e5ea; border-radius:12px; background:#fff; color:#1a1a1a; font-family:inherit; }
  input[type="number"]:focus { outline:none; border-color:#1D9E75; }
  select { width:100%; padding:11px 14px; font-size:14px; border:1.5px solid #e5e5ea; border-radius:12px; background:#fff; color:#1a1a1a; font-family:inherit; margin-top:8px; }
  select:focus { outline:none; border-color:#1D9E75; }

  /* TOTAL CARD */
  .total-card {
    background:#f9f9f9; border:1.5px solid #e5e5ea;
    border-radius:16px; padding:16px 18px;
    display:flex; justify-content:space-between; align-items:center;
    margin-bottom:24px;
  }
  .tc-left .tc-label { font-size:13px; color:#8e8e93; margin-bottom:2px; }
  .tc-left .tc-sub { font-size:11px; color:#aeaeb2; }
  .tc-right .tc-val { font-size:22px; font-weight:800; color:#1a1a1a; text-align:right; }
  .tc-right .tc-ano { font-size:11px; color:#aeaeb2; text-align:right; margin-top:2px; }

  /* CTA FINAL */
  .cta-btn {
    width:100%; padding:18px; background:#1D9E75; color:#fff;
    border:none; border-radius:16px; font-size:18px;
    font-weight:800; cursor:pointer; font-family:inherit;
    letter-spacing:-0.3px; transition:opacity 0.15s, transform 0.1s;
    display:flex; align-items:center; justify-content:center; gap:10px;
  }
  .cta-btn:disabled { opacity:0.35; cursor:not-allowed; }
  .cta-btn:not(:disabled):active { opacity:0.88; transform:scale(0.99); }
  .cta-hint { text-align:center; font-size:12px; color:#aeaeb2; margin-top:10px; margin-bottom:8px; }
  .privacy-note { text-align:center; font-size:11px; color:#c7c7cc; margin-top:8px; }
</style>
</head>
<body>
<div class="phone">
  <div class="topbar">
    <button class="back-btn" onclick="window.location.href='tela-1b-local.html'">‹</button>
    <div class="logo-name">Qual Meu Salário</div>
    <div class="step-indicator">3 de 3</div>
  </div>
  <div class="progress-bar"><div class="progress-fill"></div></div>

  <div class="content">
    <div class="step-badge">💰 Remuneração</div>
    <h1>Qual é o seu<br>salário atual?</h1>
    <p class="subtitle">Seus dados são anônimos e nunca serão compartilhados.</p>

    <!-- SALÁRIO FIXO -->
    <div class="fg">
      <label class="fg-label">Salário fixo mensal</label>
      <div class="sal-big-wrap">
        <span class="sal-prefix-big">R$</span>
        <input class="sal-big" type="number" id="sal-input" placeholder="0" oninput="updateTotal()">
      </div>
      <div class="sal-ano" id="sal-ano">—</div>
    </div>

    <!-- VARIÁVEL -->
    <div class="divider"><span>Remuneração variável (opcional)</span></div>
    <div class="extra-toggles">
      <button class="ext-tog" id="tog-com" onclick="togExtra('com')">+ Comissão</button>
      <button class="ext-tog" id="tog-plr" onclick="togExtra('plr')">+ PLR / Bônus</button>
      <button class="ext-tog" id="tog-vr"  onclick="togExtra('vr')">+ VR / VA</button>
      <button class="ext-tog" id="tog-out" onclick="togExtra('out')">+ Outros</button>
    </div>

    <div class="ext-field" id="ef-com">
      <div class="fg-label-row">
        <span class="fg-label" style="margin:0">Comissão mensal</span>
        <span class="fg-sublabel">média 3 meses</span>
      </div>
      <div class="sal-row"><span class="sal-prefix">R$</span><input type="number" id="com-v" placeholder="0" value="0" oninput="updateTotal()"></div>
    </div>

    <div class="ext-field" id="ef-plr">
      <div class="fg-label-row">
        <span class="fg-label" style="margin:0">PLR / Bônus anual</span>
        <span class="fg-sublabel">total por ano</span>
      </div>
      <div class="sal-row"><span class="sal-prefix">R$</span><input type="number" id="plr-v" placeholder="0" value="0" oninput="updateTotal()"></div>
      <select id="plr-tipo">
        <option value="plr">PLR — Participação nos Lucros</option>
        <option value="bonus">Bônus por desempenho (individual)</option>
        <option value="14sal">14º salário</option>
        <option value="participacao">Participação em resultados</option>
        <option value="stock">Stock Options / RSU (anualizado)</option>
        <option value="outro">Outro bônus anual</option>
      </select>
    </div>

    <div class="ext-field" id="ef-vr">
      <div class="fg-label-row">
        <span class="fg-label" style="margin:0">VR / VA mensal</span>
        <span class="fg-sublabel">refeição + alimentação</span>
      </div>
      <div class="sal-row"><span class="sal-prefix">R$</span><input type="number" id="vr-v" placeholder="0" value="0" oninput="updateTotal()"></div>
    </div>

    <div class="ext-field" id="ef-out">
      <div class="fg-label-row">
        <span class="fg-label" style="margin:0">Outros benefícios</span>
        <span class="fg-sublabel">saúde, gympass, home office...</span>
      </div>
      <div class="sal-row"><span class="sal-prefix">R$</span><input type="number" id="out-v" placeholder="0" value="0" oninput="updateTotal()"></div>
    </div>

    <!-- TOTAL CARD -->
    <div class="total-card">
      <div class="tc-left">
        <div class="tc-label">Pacote total mensal</div>
        <div class="tc-sub">fixo + variável + benefícios</div>
      </div>
      <div class="tc-right">
        <div class="tc-val" id="tc-val">R$ 0</div>
        <div class="tc-ano" id="tc-ano">—</div>
      </div>
    </div>

    <!-- CTA -->
    <button class="cta-btn" id="cta-btn" onclick="goAnalyze()">
      🔍 &nbsp;Ver meu resultado
    </button>
    <div class="cta-hint">Assista um breve anúncio para liberar o resultado completo</div>
    <div class="privacy-note">🔒 Seus dados são 100% anônimos</div>
  </div>
</div>

<script>
const extras = new Set();
const fmt = n => 'R$ ' + Math.round(n).toLocaleString('pt-BR');

function togExtra(id){
  const tog=document.getElementById('tog-'+id), ef=document.getElementById('ef-'+id);
  if(extras.has(id)){ extras.delete(id); tog.classList.remove('active'); ef.classList.remove('vis'); const inp=document.getElementById(id+'-v'); if(inp)inp.value=0; }
  else { extras.add(id); tog.classList.add('active'); ef.classList.add('vis'); }
  updateTotal();
}

function getMyTotal(){
  const f=parseFloat(document.getElementById('sal-input').value)||0;
  const c=extras.has('com')?(parseFloat(document.getElementById('com-v').value)||0):0;
  const p=extras.has('plr')?(parseFloat(document.getElementById('plr-v').value)||0)/12:0;
  const v=extras.has('vr')?(parseFloat(document.getElementById('vr-v').value)||0):0;
  const o=extras.has('out')?(parseFloat(document.getElementById('out-v').value)||0):0;
  return { f, c, p, v, o, total:f+c+p+v+o };
}

function updateTotal(){
  const { total, f } = getMyTotal();
  const salAno = document.getElementById('sal-ano');
  salAno.textContent = f > 0 ? fmt(f*12) + ' / ano (fixo)' : '—';
  document.getElementById('tc-val').textContent = total > 0 ? fmt(total) : 'R$ 0';
  document.getElementById('tc-ano').textContent = total > 0 ? fmt(total*12) + ' / ano' : '—';
}

function goAnalyze(){
  const sal = parseFloat(document.getElementById('sal-input').value)||0;
  if(sal <= 0){ document.getElementById('sal-input').focus(); return; }

  const d = JSON.parse(localStorage.getItem('qms_data')||'{}');
  d.salario = sal;
  d.extras = {
    com: extras.has('com') ? (parseFloat(document.getElementById('com-v').value)||0) : 0,
    plr: extras.has('plr') ? (parseFloat(document.getElementById('plr-v').value)||0) : 0,
    plrTipo: document.getElementById('plr-tipo').value,
    vr:  extras.has('vr')  ? (parseFloat(document.getElementById('vr-v').value)||0)  : 0,
    out: extras.has('out') ? (parseFloat(document.getElementById('out-v').value)||0) : 0,
  };
  localStorage.setItem('qms_data', JSON.stringify(d));
  window.location.href = 'tela-2-reward.html';
}
</script>
</body>
</html>
