<resources xmlns:tools="http://schemas.android.com/tools">
  <!-- Android 12+ usa SplashScreen API, mas forcamos logo grande -->
  <style name="Theme.App.SplashScreen" parent="Theme.AppCompat.Light.NoActionBar">
    <item name="android:windowBackground">@drawable/splash_fullscreen</item>
    <item name="android:statusBarColor">#0B1838</item>
    <item name="android:navigationBarColor">#0B1838</item>
    <item name="android:windowSplashScreenBackground" tools:targetApi="31">#0B1838</item>
    <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@drawable/splashscreen_logo</item>
    <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="31">#0B1838</item>
  </style>
</resources>
