{
  "version": 2,
  "name": "qualmeusalario",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/calcular",  "destination": "/public/tela-1a-cargo.html" },
    { "source": "/resultado", "destination": "/public/tela-3-resultado.html" }
  ]
}